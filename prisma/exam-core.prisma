generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma-exam-core/client"
}

datasource db {
  provider = "postgresql"
  url      = env("EXAM_CORE_DATABASE_URL")
}

model Board {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  country   String   @default("India")
  createdAt DateTime @default(now()) @map("created_at")

  classes   Class[]

  @@map("boards")
}

model Class {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  name      String
  levelNum  Int      @map("level_num")
  createdAt DateTime @default(now()) @map("created_at")

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  subjects  Subject[]

  @@index([boardId])
  @@map("classes")
}

model Subject {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  name      String
  code      String
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")

  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  chapters  Chapter[]

  @@index([classId])
  @@map("subjects")
}

model Chapter {
  id                  String   @id @default(uuid())
  subjectId           String   @map("subject_id")
  name                String
  orderIndex          Int      @default(0) @map("order_index")
  weightagePercentage Float?   @map("weightage_percentage")
  createdAt           DateTime @default(now()) @map("created_at")

  subject             Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics              Topic[]

  @@index([subjectId, orderIndex])
  @@map("chapters")
}

model Topic {
  id         String   @id @default(uuid())
  chapterId  String   @map("chapter_id")
  name       String
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")

  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId, orderIndex])
  @@map("topics")
}
